---
layout: layouts/base.njk
title: Multimedia
description: Videoteca institucional de la Secretaría de Vivienda y Asentamientos Humanos (SEVIAH) — videos por playlist.
---
{% from "video-embed.njk" import video_embed %}
{% set playlists = ["Institucional", "Programas", "Eventos", "SEVIAH en Acción"] %}
{% set bloques = videos | groupby("formato") %}

<section class="section section--suave">
  <div class="container">
    <div class="row align-items-center g-3">
      <div class="col-lg-8">
        <p class="eyebrow">Videoteca institucional</p>
        <h1 class="section-title">Multimedia</h1>
        <p class="section-lead mb-0">Videos de la Secretaría de Vivienda y Asentamientos Humanos, organizados por playlist. Los videos que aún no se han publicado en el canal se muestran como pendientes.</p>
      </div>
      <div class="col-lg-4 text-lg-end">
        <a class="btn-sev" href="#">Suscríbete a nuestro canal</a>
        <p class="mt-2 mb-0"><span class="badge-estado">Canal de YouTube en construcción</span></p>
      </div>
    </div>
  </div>
</section>

{# D-13 (AJUSTE-02): un contenedor por formato; el filtro opera dentro de cada bloque y un
   bloque sin resultados se oculta completo. #}
<section class="section">
  <div class="container">
    <div class="playlist-filtros" role="group" aria-label="Filtrar videos por playlist">
      <button class="playlist-filtro is-active" type="button" data-playlist-filtro="todas">Todas</button>
      {% for pl in playlists %}
        <button class="playlist-filtro" type="button" data-playlist-filtro="{{ pl }}">{{ pl }}</button>
      {% endfor %}
    </div>

    {% if bloques.horizontal | length %}
      <div class="bloque-videos" data-formato="horizontal">
        <div class="section-heading">
          <p class="eyebrow">Formato horizontal</p>
          <h2 class="section-title">Videos</h2>
        </div>
        <div class="row g-4">
          {% for v in bloques.horizontal %}
            <div class="col-md-6 col-lg-4" data-playlist="{{ v.playlist }}">
              <p class="video-card__meta">{{ v.playlist }}</p>
              {{ video_embed(v, true) }}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if bloques.vertical | length %}
      <div class="bloque-videos" data-formato="vertical">
        <div class="section-heading">
          <p class="eyebrow">Formato vertical</p>
          <h2 class="section-title">SEVIAH Shorts</h2>
        </div>
        <div class="shorts-fila">
          {% for v in bloques.vertical %}
            <div class="shorts-fila__item" data-playlist="{{ v.playlist }}">
              <p class="video-card__meta">{{ v.playlist }}</p>
              {{ video_embed(v, true) }}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>
