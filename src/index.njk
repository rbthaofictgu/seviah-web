---
layout: layouts/base.njk
title: Inicio
description: Secretaría de Vivienda y Asentamientos Humanos (SEVIAH) — ente rector de la política pública de vivienda y asentamientos humanos de Honduras.
---
{% from "hero.njk" import hero %}
{% from "card-destacado.njk" import card_destacado %}
{% from "card-noticia.njk" import card_noticia %}
{% from "video-embed.njk" import video_embed %}
{% from "redes-sociales.njk" import redes_banda %}

{# D-15 (AJUSTE-04-D1): carrusel con fotografías institucionales propias (fotogramas de
   videos oficiales, adenda AJUSTE-04). Las 10 imágenes no usadas de src/assets/img/hero/
   quedan como reserva editorial. #}
{% set slides = [
  { imagen: "/assets/img/hero/hero-congreso-02.jpg",
    alt: "Auditorio del Congreso Municipal Sobre Gestión de Riesgos, con las banderas de los países participantes y el público siguiendo la ponencia",
    eyebrow: "Secretaría de Vivienda y Asentamientos Humanos",
    titulo: "Construyendo un mejor futuro para Honduras",
    texto: "Ente rector de la política pública de vivienda y asentamientos humanos de Honduras.",
    cta_url: "/programas/", cta_texto: "Conozca nuestros programas" },
  { imagen: "/assets/img/hero/hero-emergencia-01.jpg",
    alt: "Vivienda afectada por un incendio en Yauyupe, El Paraíso, durante la atención en campo del equipo de SEVIAH",
    eyebrow: "SEVIAH en acción",
    titulo: "Atención cercana y responsable",
    texto: "Acompañamos a las familias afectadas por emergencias con soluciones habitacionales dignas.",
    cta_url: "/multimedia/", cta_texto: "SEVIAH en Acción" },
  { imagen: "/assets/img/hero/hero-vivienda-digna-01.jpg", variante: "dorado",
    alt: "Madre e hijo de la familia de Yauyupe que recibirá una vivienda donada, sonriendo frente a la vegetación de su comunidad",
    eyebrow: "Pilares institucionales",
    titulo: "Vivienda digna para todos",
    texto: "El Bono de Vivienda de Interés Social y el mejoramiento de vivienda, al servicio de las familias hondureñas.",
    cta_url: "/nosotros/", cta_texto: "Conozca la SEVIAH" }
] %}

{{ hero(slides, true) }}

<section class="section section--suave">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Conozca la SEVIAH</p>
      <h2 class="section-title">Destacados</h2>
    </div>
    <div class="swiper destacados-swiper">
      <div class="swiper-wrapper">
        {# D-15 (AJUSTE-04-D3): AOS en el contenido de cada slide (no en .swiper-slide,
           cuyo transform administra Swiper) #}
        <div class="swiper-slide h-auto"><div class="h-100" data-aos="fade-up">{{ card_destacado("fa-solid fa-house-chimney", "Bono de Vivienda (BVIS)", "Aporte estatal para familias de escasos recursos conforme a la Ley Marco.", "/programas/") }}</div></div>
        <div class="swiper-slide h-auto"><div class="h-100" data-aos="fade-up" data-aos-delay="100">{{ card_destacado("fa-solid fa-trowel-bricks", "Mejoramiento de Vivienda", "Intervenciones de mejora en vivienda existente.", "/programas/") }}</div></div>
        <div class="swiper-slide h-auto"><div class="h-100" data-aos="fade-up" data-aos-delay="200">{{ card_destacado("fa-solid fa-diagram-project", "SIGEBO", "Sistema Integrado de Gestión del Bono de Vivienda de Interés Social.", "/sistemas/") }}</div></div>
        <div class="swiper-slide h-auto"><div class="h-100" data-aos="fade-up" data-aos-delay="300">{{ card_destacado("fa-solid fa-folder-tree", "SIGEPO", "Sistema Integrado de Gestión de Proyectos.", "/sistemas/") }}</div></div>
      </div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Sala de prensa</p>
      <h2 class="section-title">Noticias</h2>
    </div>
    <div class="row g-4">
      {% for n in noticias %}
        {% if loop.index <= 3 %}
          <div class="col-md-4" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 }}">{{ card_noticia(n, videos | buscarPorSlug(n.video_slug)) }}</div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="text-center mt-4">
      <a class="btn-sev" href="/noticias/">Mostrar Más</a>
    </div>
  </div>
</section>

{# D-13 (AJUSTE-02): la franja solo reproduce destacados verticales; los destacados
   horizontales se promocionan como card de noticia enlazada a /multimedia/. #}
{% set destacados = videos | selectattr("destacado") | list | groupby("formato") %}
<section class="section section--oscuro">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Multimedia</p>
      <h2 class="section-title">Videos institucionales</h2>
    </div>
    <div class="row g-4 justify-content-center" data-formato="vertical">
      {% for v in destacados.vertical %}
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 }}">{{ video_embed(v) }}</div>
      {% endfor %}
    </div>
    {% if destacados.horizontal | length %}
      <div class="row g-4 justify-content-center mt-1">
        {% for v in destacados.horizontal %}
          <div class="col-md-6 col-lg-4" data-aos="fade-up">
            <article class="card-noticia">
              {# D-15 (AJUSTE-04-D5): la card-enlace consume la miniatura oficial de
                 YouTube construida desde el youtube_id del contrato (D-05). #}
              <a class="card-video__media" href="/multimedia/"
                 aria-label="Ver el video «{{ v.titulo }}» en la videoteca">
                <img class="card-video__thumb"
                     src="https://i.ytimg.com/vi/{{ v.youtube_id }}/hqdefault.jpg"
                     alt="Miniatura del video: {{ v.titulo }}"
                     loading="lazy" width="480" height="360">
                <span class="card-video__velo" aria-hidden="true"></span>
                <span class="card-video__play" aria-hidden="true"><i class="fa-solid fa-play"></i></span>
              </a>
              <div class="card-noticia__body">
                <p class="card-noticia__date">Video · {{ v.playlist }}</p>
                <h3 class="card-noticia__title">{{ v.titulo }}</h3>
                <p class="card-noticia__excerpt">{{ v.descripcion }}</p>
                <a class="card-noticia__link" href="/multimedia/">Ver en la videoteca <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
              </div>
            </article>
          </div>
        {% endfor %}
      </div>
    {% endif %}
    <div class="text-center mt-4">
      <a class="btn-sev" href="/multimedia/">Ver videoteca</a>
    </div>
  </div>
</section>

{# D-14 (AJUSTE-03): banda de redes antes del footer #}
{{ redes_banda(redes) }}
