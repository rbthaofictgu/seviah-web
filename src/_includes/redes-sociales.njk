{#
  redes-sociales.njk — Sección "Síguenos en redes" (D-14, AJUSTE-03; docs/03 §3).
  Variantes: banda (Inicio antes del footer y /contacto/) e inline (footer y ficha de
  Contacto). Datos: src/_data/redes.json — las cinco redes oficiales (D-12), únicas
  permitidas. Insignias en colores institucionales, nunca los de cada plataforma.
#}
{% macro redes_banda(redes) %}
<section class="redes-banda">
  <div class="container">
    <h2 class="redes-banda__title">Síguenos en nuestras redes</h2>
    <ul class="redes-banda__lista">
      {% for red in redes %}
        <li>
          <a class="redes-banda__enlace" href="{{ red.url }}" aria-label="SEVIAH en {{ red.red }}: {{ red.nombre }}" rel="noopener" target="_blank">
            <span class="redes-banda__circulo"><i class="{{ red.icono }}" aria-hidden="true"></i></span>
            <span class="redes-banda__nombre">{{ red.nombre }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
    <div class="redes-banda__cta">
      <a class="btn-sev" href="https://www.youtube.com/@seviahn?sub_confirmation=1" rel="noopener" target="_blank">Suscríbete a nuestro canal</a>
    </div>
  </div>
</section>
{% endmacro %}

{% macro redes_inline(redes) %}
<ul class="redes-inline">
  {% for red in redes %}
    <li>
      <a class="redes-inline__enlace" href="{{ red.url }}" aria-label="SEVIAH en {{ red.red }}: {{ red.nombre }}" rel="noopener" target="_blank">
        <i class="{{ red.icono }}" aria-hidden="true"></i>
      </a>
    </li>
  {% endfor %}
</ul>
{% endmacro %}
