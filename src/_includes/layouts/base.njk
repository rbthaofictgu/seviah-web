<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} · SEVIAH</title>
    <meta name="description" content="{{ description or 'Secretaría de Vivienda y Asentamientos Humanos (SEVIAH) — Gobierno de la República de Honduras. Construyendo un mejor futuro para Honduras.' }}">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/img/favicon-192.png">
    <link rel="apple-touch-icon" href="/assets/img/favicon-192.png">
    <meta property="og:title" content="{{ title }} · SEVIAH">
    <meta property="og:image" content="/assets/img/favicon-512.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    {# D-15 (AJUSTE-04-D3): AOS — animaciones sobrias al hacer scroll (CDN permitido, D-03) #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">
    {# v= fuerza el refresco de caché de los assets propios en cada revisión #}
    <link rel="stylesheet" href="/assets/css/tokens.css?v=20260723-11">
    <link rel="stylesheet" href="/assets/css/main.css?v=20260723-11">
    {# D-15 (AJUSTE-04-D2, revisión del usuario): el preloader se muestra en cada página
       y en cada visita (paridad con el loader de la SIT). Aquí, antes del primer pintado,
       solo se bloquea el scroll y se arma el failsafe (duración + 2.5s), que debe disparar aunque
       los scripts de CDN (que preceden a main.js) tarden. Nomenclatura sev-cargador:
       los filtros cosméticos de los bloqueadores ocultan selectores genéricos tipo
       .preloader/#preloader. #}
    <script>(function(){var d=document.documentElement;d.className+=" con-cargador";setTimeout(function(){d.className=d.className.replace(" con-cargador"," cargador-vencido")},5500)})()</script>
  </head>
  <body>
    {# D-15 (AJUSTE-04-D2): preloader institucional propio. Replica la coreografía del
       loader de www.sit.gob.hn (logo estático sobre halo giratorio de círculos
       desenfocados y salida por fade) reimplementada desde cero con CSS propio y el
       escudo SEVIAH — ningún activo de la SIT se descarga al repo (D-03). #}
    <div class="sev-cargador" id="sevCargador" data-preloader="seviah" aria-hidden="true">
      <div class="sev-cargador__anillo"><span></span><span></span><span></span><span></span></div>
      <span class="sev-cargador__orbita"></span>
      <img class="sev-cargador__escudo" src="/assets/img/logo-seviah-blanco-escudo.png"
           alt="" width="96" height="96">
      <p class="sev-cargador__lema">Construyendo un mejor futuro para Honduras</p>
    </div>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    {% include "partials/header.njk" %}
    <main id="contenido">
      {{ content | safe }}
    </main>
    {% include "partials/footer.njk" %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script src="/assets/js/main.js?v=20260723-11"></script>
  </body>
</html>
